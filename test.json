{
    "apps": [
      {
        "name": "dashboard",
        "description": "Frontend app for user dashboard and feature UIs"
      },
      {
        "name": "api",
        "description": "Backend API service using Express.js"
      }
    ],
    "libs": {
      "shared": ["utils", "types", "ui"],
      "dashboard": ["ui", "state", "api"],
      "features": ["notifications", "team-invites"]
    },
    "namespaces": {
      "@shared/utils": "libs/shared/utils/src/index.ts",
      "@shared/types": "libs/shared/types/src/index.ts",
      "@dashboard/ui": "libs/dashboard/ui/src/index.ts",
      "@dashboard/api": "libs/dashboard/api/src/index.ts",
      "@features/notifications": "libs/features/notifications/src/index.ts"
    },
    "features": [
      {
        "name": "notifications",
        "description": "User notifications panel in dashboard with real-time updates.",
        "tasks": [
          {
            "description": "Create notifications feature lib",
            "target_path": "libs/features/notifications"
          },
          {
            "description": "Add NotificationWidget UI component",
            "target_path": "libs/dashboard/ui",
            "dependencies": ["libs/features/notifications"]
          },
          {
            "description": "Create useNotifications API hook",
            "target_path": "libs/dashboard/api"
          },
          {
            "description": "Add types for Notification in shared/types",
            "target_path": "libs/shared/types"
          },
          {
            "description": "Integrate NotificationWidget into dashboard homepage",
            "target_path": "apps/dashboard/src/app/pages"
          }
        ]
      }
    ]
  }